#!/bin/bash

usage() {
	echo "Usage: $(basename "$0") [-h] [-p <prefix>] directory1 [directory2 ...]"
}

commit_message_prefix="Auto Commit"

while getopts "hp:" arg; do
	case $arg in
	h)
		usage
		exit 0
		;;
	p)
		commit_message_prefix="$OPTARG"
		;;
	*)
		usage
		exit 1
		;;
	esac
done
shift $((OPTIND - 1))
if [[ $# -eq 0 ]]; then
	usage
	exit 0
fi

set -e

directories=("$@")

for full_path in "${directories[@]}"; do
	if [[ ! -d "$full_path" ]]; then
		echo.error "$full_path not exist"
		continue
	fi
	if ! (cd "$full_path" && git rev-parse --is-inside-work-tree &>/dev/null); then
		echo.warn "$full_path is not a git repository"
		continue
	fi
	echo "Auto Commit: $full_path"
	commit_message="$commit_message_prefix - $(basename "$full_path") $(y2s)"

	(
		cd "$full_path"
		CHANGES=$(git status --porcelain .)

		if [[ -z $CHANGES ]]; then
			echo.info "No Changes"
		else
			(
				set -x
				git add .
				git commit -m "$commit_message"
			)
		fi
	)
done
